{
  "title": "Blinkit — Stage 2: All Services Overview",
  "uid": "blinkit-stage2",
  "schemaVersion": 38,
  "version": 3,
  "refresh": "30s",
  "tags": ["blinkit", "stage2", "all-services"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "annotations": { "list": [] },
  "templating": { "list": [] },
  "links": [],
  "panels": [

    {
      "id": 1,
      "type": "table",
      "title": "Service Health Overview",
      "description": "Status, CPU, RAM, Heap, Uptime for all services",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 10 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Service", "desc": false }],
        "footer": { "show": false }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left",
            "displayMode": "auto"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Status" },
            "properties": [
              { "id": "custom.width", "value": 100 },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "0": { "text": "DOWN", "color": "red",   "index": 0 },
                      "1": { "text": "UP",   "color": "green", "index": 1 }
                    }
                  }
                ]
              },
              { "id": "custom.displayMode", "value": "color-background" },
              { "id": "color", "value": { "mode": "thresholds" } },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "red",   "value": null },
                    { "color": "green", "value": 1 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "CPU %" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "decimals", "value": 2 },
              { "id": "custom.width", "value": 100 },
              { "id": "custom.displayMode", "value": "color-background" },
              { "id": "color", "value": { "mode": "thresholds" } },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green",  "value": null },
                    { "color": "yellow", "value": 40 },
                    { "color": "red",    "value": 75 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "RAM MB" },
            "properties": [
              { "id": "unit", "value": "none" },
              { "id": "decimals", "value": 0 },
              { "id": "custom.width", "value": 100 },
              { "id": "custom.displayMode", "value": "color-background" },
              { "id": "color", "value": { "mode": "thresholds" } },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green",  "value": null },
                    { "color": "yellow", "value": 300 },
                    { "color": "red",    "value": 500 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Heap MB" },
            "properties": [
              { "id": "unit", "value": "none" },
              { "id": "decimals", "value": 0 },
              { "id": "custom.width", "value": 100 },
              { "id": "custom.displayMode", "value": "color-background" },
              { "id": "color", "value": { "mode": "thresholds" } },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green",  "value": null },
                    { "color": "yellow", "value": 250 },
                    { "color": "red",    "value": 350 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Uptime" },
            "properties": [
              { "id": "unit", "value": "dtdurations" },
              { "id": "decimals", "value": 0 },
              { "id": "custom.width", "value": 130 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Threads" },
            "properties": [
              { "id": "unit", "value": "short" },
              { "id": "decimals", "value": 0 },
              { "id": "custom.width", "value": 90 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Service" },
            "properties": [
              { "id": "custom.width", "value": 180 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Time" },
            "properties": [
              { "id": "custom.hidden", "value": true }
            ]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(up{job!=\"node-exporter\"}) by (job)",
          "instant": true,
          "legendFormat": "{{job}}",
          "format": "table"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(process_cpu_usage{job!=\"node-exporter\"}) by (job) * 100",
          "instant": true,
          "legendFormat": "{{job}}",
          "format": "table"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(jvm_memory_used_bytes{job!=\"node-exporter\"}) by (job) / 1048576",
          "instant": true,
          "legendFormat": "{{job}}",
          "format": "table"
        },
        {
          "refId": "D",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(jvm_memory_used_bytes{job!=\"node-exporter\", area=\"heap\"}) by (job) / 1048576",
          "instant": true,
          "legendFormat": "{{job}}",
          "format": "table"
        },
        {
          "refId": "E",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max(process_uptime_seconds{job!=\"node-exporter\"}) by (job)",
          "instant": true,
          "legendFormat": "{{job}}",
          "format": "table"
        },
        {
          "refId": "F",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max(jvm_threads_live_threads{job!=\"node-exporter\"}) by (job)",
          "instant": true,
          "legendFormat": "{{job}}",
          "format": "table"
        }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "job":      "Service",
              "Value #A": "Status",
              "Value #B": "CPU %",
              "Value #C": "RAM MB",
              "Value #D": "Heap MB",
              "Value #E": "Uptime",
              "Value #F": "Threads"
            },
            "indexByName": {
              "Service": 0,
              "Status":  1,
              "CPU %":   2,
              "RAM MB":  3,
              "Heap MB": 4,
              "Threads": 5,
              "Uptime":  6
            }
          }
        }
      ]
    },

    {
      "id": 2,
      "type": "timeseries",
      "title": "CPU Usage — All Services",
      "gridPos": { "x": 0, "y": 10, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 5 }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(process_cpu_usage{job!=\"node-exporter\"}) by (job) * 100",
          "legendFormat": "{{job}}"
        }
      ]
    },

    {
      "id": 3,
      "type": "timeseries",
      "title": "Heap Memory — All Services",
      "gridPos": { "x": 12, "y": 10, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 5 }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(jvm_memory_used_bytes{job!=\"node-exporter\", area=\"heap\"}) by (job)",
          "legendFormat": "{{job}}"
        }
      ]
    },

    {
      "id": 4,
      "type": "timeseries",
      "title": "HTTP Request Rate — All Services (req/sec)",
      "gridPos": { "x": 0, "y": 18, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 3,
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 5 }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(http_server_requests_seconds_count{job!=\"node-exporter\"}[1m])) by (job)",
          "legendFormat": "{{job}}"
        }
      ]
    },

    {
      "id": 5,
      "type": "timeseries",
      "title": "HTTP Avg Response Time — All Services (ms)",
      "gridPos": { "x": 12, "y": 18, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 1,
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 5 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red",    "value": 1500 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "1000 * sum(rate(http_server_requests_seconds_sum{job!=\"node-exporter\"}[1m])) by (job) / sum(rate(http_server_requests_seconds_count{job!=\"node-exporter\"}[1m])) by (job)",
          "legendFormat": "{{job}}"
        }
      ]
    },

    {
      "id": 6,
      "type": "timeseries",
      "title": "Live Threads — All Services",
      "gridPos": { "x": 0, "y": 26, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 5 }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max(jvm_threads_live_threads{job!=\"node-exporter\"}) by (job)",
          "legendFormat": "{{job}}"
        }
      ]
    },

    {
      "id": 7,
      "type": "timeseries",
      "title": "Total RAM Used — All Services (bytes)",
      "gridPos": { "x": 12, "y": 26, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 5 }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(jvm_memory_used_bytes{job!=\"node-exporter\"}) by (job)",
          "legendFormat": "{{job}}"
        }
      ]
    }

  ]
}
