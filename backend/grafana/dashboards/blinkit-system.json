{
  "title": "Blinkit — System Resources & Configuration",
  "uid": "blinkit-system",
  "schemaVersion": 38,
  "version": 2,
  "refresh": "30s",
  "tags": ["blinkit", "system", "infrastructure"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "annotations": { "list": [] },
  "templating": { "list": [] },
  "links": [],
  "panels": [

    { "id": 100, "type": "text", "title": "", "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "options": { "mode": "markdown", "content": "## System Configuration" }, "fieldConfig": { "defaults": {}, "overrides": [] } },

    {
      "id": 1,
      "type": "stat",
      "title": "CPU Cores",
      "gridPos": { "x": 0, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "none",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "text", "value": null }] }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "count(count(node_cpu_seconds_total{job=\"node-exporter\"}) by (cpu))",
          "instant": true,
          "legendFormat": "Cores"
        }
      ]
    },

    {
      "id": 2,
      "type": "stat",
      "title": "Total RAM",
      "gridPos": { "x": 4, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "none",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "decimals": 1,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "text", "value": null }] }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "node_memory_MemTotal_bytes{job=\"node-exporter\"}",
          "instant": true,
          "legendFormat": "Total RAM"
        }
      ]
    },

    {
      "id": 3,
      "type": "stat",
      "title": "Total Disk (SSD)",
      "gridPos": { "x": 8, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "none",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "decimals": 1,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "text", "value": null }] }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "node_filesystem_size_bytes{job=\"node-exporter\", mountpoint=\"/\"}",
          "instant": true,
          "legendFormat": "Total Disk"
        }
      ]
    },

    {
      "id": 4,
      "type": "stat",
      "title": "OS / Kernel",
      "gridPos": { "x": 12, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "value",
        "colorMode": "none",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "string",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "text", "value": null }] }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "node_uname_info{job=\"node-exporter\"}",
          "instant": true,
          "legendFormat": "{{sysname}} {{release}} ({{machine}})"
        }
      ]
    },

    {
      "id": 5,
      "type": "stat",
      "title": "Services Running",
      "gridPos": { "x": 18, "y": 1, "w": 3, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 8 },
              { "color": "green",  "value": 10 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "count(up{job!=\"node-exporter\"} == 1)",
          "instant": true,
          "legendFormat": "Services"
        }
      ]
    },

    {
      "id": 6,
      "type": "stat",
      "title": "Services Down",
      "gridPos": { "x": 21, "y": 1, "w": 3, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red",   "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "count(up{job!=\"node-exporter\"} == 0) or vector(0)",
          "instant": true,
          "legendFormat": "Down"
        }
      ]
    },

    { "id": 101, "type": "text", "title": "", "gridPos": { "x": 0, "y": 5, "w": 24, "h": 1 },
      "options": { "mode": "markdown", "content": "## Current Resource Usage" }, "fieldConfig": { "defaults": {}, "overrides": [] } },

    {
      "id": 7,
      "type": "stat",
      "title": "CPU Usage %",
      "gridPos": { "x": 0, "y": 6, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red",    "value": 85 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "(1 - avg(rate(node_cpu_seconds_total{job=\"node-exporter\", mode=\"idle\"}[1m]))) * 100",
          "instant": true,
          "legendFormat": "CPU %"
        }
      ]
    },

    {
      "id": 8,
      "type": "stat",
      "title": "RAM Used",
      "gridPos": { "x": 4, "y": 6, "w": 4, "h": 4 },
