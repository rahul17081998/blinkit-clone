# ─────────────────────────────────────────────────────────────────
# .env.example — Template for environment-specific env files.
#
# Usage:
#   cp .env.example .env.dev   → fill in local dev values
#   cp .env.example .env.prod  → fill in production values
#
# Starting services:
#   ./start-backend.sh          → uses .env.dev  (default)
#   ./start-backend.sh dev      → uses .env.dev
#   ./start-backend.sh prod     → uses .env.prod
#
# Both .env.dev and .env.prod are git-ignored.
# NEVER commit real secrets.
# ─────────────────────────────────────────────────────────────────

# ─── MongoDB Atlas ────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0

# ─── JWT ──────────────────────────────────────────────────────────
# Must be at least 32 characters
JWT_SECRET_KEY=<your-jwt-secret-min-32-chars>
JWT_EXPIRY_TIME_IN_MINUTE=15
JWT_REFRESH_EXPIRY_DAYS=30

# ─── Internal Service Secret ──────────────────────────────────────
# Used by API Gateway to authenticate internal service calls
INTERNAL_SECRET=<your-internal-service-secret>

# ─── Redis ────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=<your-redis-password>

# ─── Kafka ────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
# For Upstash Kafka (prod only) — SASL credentials
KAFKA_SASL_USERNAME=<upstash-kafka-username>
KAFKA_SASL_PASSWORD=<upstash-kafka-password>

# ─── Eureka & Config Server ───────────────────────────────────────
EUREKA_SERVER_URL=http://localhost:8761/eureka
CONFIG_SERVER_URL=http://localhost:8888

# ─── Service Ports ────────────────────────────────────────────────
EUREKA_PORT=8761
CONFIG_SERVER_PORT=8888
GATEWAY_PORT=8080
AUTH_SERVICE_PORT=8081
USER_SERVICE_PORT=8082
PRODUCT_SERVICE_PORT=8083
INVENTORY_SERVICE_PORT=8084
ORDER_SERVICE_PORT=8085
PAYMENT_SERVICE_PORT=8086
CART_SERVICE_PORT=8087
DELIVERY_SERVICE_PORT=8088
NOTIFICATION_SERVICE_PORT=8089
COUPON_SERVICE_PORT=8090
REVIEW_SERVICE_PORT=8091

# ─── Email (SMTP) ─────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# ─── Frontend URL (for CORS) ──────────────────────────────────────
# dev: http://localhost:5173  |  prod: https://your-app.vercel.app
FRONTEND_URL=http://localhost:5173

SMTP_USERNAME=<your-gmail-address>
SMTP_PASSWORD=<your-gmail-app-password>
PASSWORD_RESET_BASE_URL=http://localhost:5174/reset-password
ADMIN_EMAIL=<your-admin-email-address>

# ─── Auth Expiry ───────────────────────────────────────────────────
OTP_EXPIRY_MINUTES=5
PASSWORD_RESET_EXPIRY_MINUTES=15

# ─── Inventory ─────────────────────────────────────────────────────
INVENTORY_LOW_STOCK_THRESHOLD=10

# ─── Delivery Service ──────────────────────────────────────────────
DELIVERY_STORE_NAME="Blinkit Warehouse"
DELIVERY_STORE_ADDRESS="Bangalore, India"
DELIVERY_STORE_LAT=12.9352
DELIVERY_STORE_LNG=77.6245
DELIVERY_COOLDOWN_MINUTES=5
DELIVERY_ETA_MINUTES=30

# ─── Delivery Scheduler (milliseconds) ────────────────────────────
SCHEDULING_RETRY_UNASSIGNED_MS=30000
SCHEDULING_RELEASE_COOLDOWN_MS=60000
SCHEDULING_AUTO_COMPLETE_MS=300000
SCHEDULING_SIMULATE_PROGRESS_MS=30000

# ─── Cloudinary (CDN) ─────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=<your-cloud-name>
CLOUDINARY_API_KEY=<your-api-key>
CLOUDINARY_API_SECRET=<your-api-secret>
